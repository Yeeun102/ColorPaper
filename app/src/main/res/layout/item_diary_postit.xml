<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="0dp">

    <!-- 💡 포스트잇 SVG 배경을 깔아주는 곳 -->
    <ImageView
        android:id="@+id/ivPostItBg"
        android:layout_width="260dp"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        android:src="@drawable/post_yellow"
        android:contentDescription="@string/postit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 날짜 라벨 (와이어프레임 내부 6월 30일 표기용) -->
    <TextView
        android:id="@+id/tvPostItDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="today"
        android:textSize="14sp"
        android:textColor="#333333"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="@id/ivPostItBg"
        app:layout_constraintStart_toStartOf="@id/ivPostItBg"/>

    <!-- 일기 내용을 입력하는 칸 -->
    <EditText
        android:id="@+id/etPostItContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/transparent"
        android:gravity="top|start"
        android:hint="@string/entryHint"
        android:textSize="15sp"
        android:textColor="#222222"
        app:layout_constraintTop_toBottomOf="@id/tvPostItDate"
        app:layout_constraintBottom_toBottomOf="@id/ivPostItBg"
        app:layout_constraintStart_toStartOf="@id/ivPostItBg"
        app:layout_constraintEnd_toEndOf="@id/ivPostItBg"/>

    <!-- 와이어프레임 우측 하단의 삭제/설정용 카메라 혹은 이미지 버튼 -->
    <ImageButton
        android:id="@+id/btnPostItMenu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_camera"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="@id/ivPostItBg"
        app:layout_constraintEnd_toEndOf="@id/ivPostItBg"
        android:contentDescription="@string/postit_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>