<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F8">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/home_horizontal_padding"
        android:paddingTop="@dimen/home_header_top_padding"
        android:paddingEnd="@dimen/home_horizontal_padding"
        android:paddingBottom="@dimen/home_header_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_date_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#443838"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="7월 21일" />

        <TextView
            android:id="@+id/btn_edit_layout"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_home_edit_button"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingHorizontal="14dp"
            android:text="배치 편집"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_home_widgets"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/home_horizontal_padding"
        android:paddingTop="4dp"
        android:paddingEnd="@dimen/home_horizontal_padding"
        android:paddingBottom="@dimen/home_horizontal_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        tools:listitem="@layout/item_home_widget" />

</androidx.constraintlayout.widget.ConstraintLayout>
