<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.profile.ProfileEditFragment">

    <!-- 상단 타이틀바 (뒤로가기 & 타이틀) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:src="@android:drawable/ic_menu_revert" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="프로필 수정하기"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 중앙 카드 구역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FDF3F3"
        android:layout_marginTop="30dp"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 프로필 사진 구역 -->
        <ImageView
            android:id="@+id/ivEditProfileImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@android:drawable/ic_menu_report_image" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="프로필 사진"
            android:layout_marginTop="8dp"
            android:textColor="#555555"
            android:textSize="14sp"/>

        <!-- 닉네임 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="닉네임"
            android:textColor="#888888"
            android:layout_marginTop="20dp"/>
        <EditText
            android:id="@+id/etNickname"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="#FFFFFF"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="12dp"
            android:hint="닉네임을 입력하세요"
            android:inputType="text"/>

        <!-- 사용자 아이디 입력 (user_code 매핑) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="사용자 아이디"
            android:textColor="#888888"
            android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/etUserCode"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="#FFFFFF"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="12dp"
            android:hint="아이디를 입력하세요"
            android:inputType="text"/>
    </LinearLayout>

    <!-- 저장 버튼 -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:backgroundTint="#E8D3D3"
        android:textColor="#000000"
        android:text="저장"
        android:textStyle="bold" />

</LinearLayout>