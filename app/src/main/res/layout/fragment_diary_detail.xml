<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:padding="16dp">

    <!-- [상단 바] 과거 날짜 고정 영역 -->
    <TextView
        android:id="@+id/tvDetailDateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026-06-30"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 📍 작성 페이지의 lineHeader와 오차가 없도록 완전히 동일한 마진값(8dp) 세팅 -->
    <View
        android:id="@+id/lineHeaderDetail"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailDateTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================================================================= -->
    <!-- 💡 [위치 고정층] 작성 페이지와 100% 동일한 좌표값으로 박아두는 배경 이미지 -->
    <!-- ================================================================= -->
    <ImageView
        android:id="@+id/ivFixedDiaryPageDetail"
        android:layout_width="0dp"
        android:layout_height="500dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="300dp"
        android:scaleType="fitXY"
        android:src="@drawable/diarypage"
        android:contentDescription="@string/diarypage"
        app:layout_constraintTop_toBottomOf="@id/lineHeaderDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- [중앙 콘텐츠 구역] 투명 스크롤 레이어 (과거 일기 본문 + 셀프 댓글 목록) -->

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="450dp"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="0dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="150dp"
            app:layout_constraintTop_toTopOf="@id/ivFixedDiaryPageDetail"
            app:layout_constraintBottom_toBottomOf="@id/ivFixedDiaryPageDetail"
            app:layout_constraintStart_toStartOf="@id/ivFixedDiaryPageDetail"
            app:layout_constraintEnd_toEndOf="@id/ivFixedDiaryPageDetail">

            <!-- 과거 일기 본문 스킨 컨테이너 -->
            <LinearLayout
                android:id="@+id/layoutDetailDiaryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp" />

            <!-- 셀프 댓글 배치 스택 컨테이너 -->
            <LinearLayout
                android:id="@+id/layoutCommentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    <!-- 하단 제어 바 (과거 날짜이므로 저장은 숨김 처리용 GONE 배치 예정) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutMetaActionsDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarDecorateDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnVisibilityDetail"
            style="?android:attr/buttonStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/flashcard_public"
            android:background="@android:color/transparent"
            android:textColor="#555555"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <Button
            android:id="@+id/btnSaveDetail"
            android:layout_width="70dp"
            android:layout_height="36dp"
            android:text="@string/save"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutToolbarDecorateDetail"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@android:color/darker_gray"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarNavDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnToolbarAddDetail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="과거일기 추가 불가" />

        <ImageButton
            android:id="@+id/btnToolbarPenDetail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_edit" />

        <ImageButton
            android:id="@+id/btnToolbarTextDetail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_sort_alphabetically" />

        <ImageButton
            android:id="@+id/btnToolbarCommentDetail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/sym_action_chat"
            android:contentDescription="셀프 댓글 작성 창 열기" />
    </LinearLayout>


    <!-- 하단 툴바 2: 네비게이션 공용 링 -->
    <LinearLayout
        android:id="@+id/layoutToolbarNavDetail"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@android:color/darker_gray"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_agenda" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_book" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_gallery" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_myplaces" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_manage" />
        -->
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>