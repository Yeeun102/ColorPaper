<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layoutDateSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lineHeader">

        <TextView
            android:id="@+id/tvDateTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6월 30일"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <ImageButton
            android:id="@+id/btnDatePicker"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:contentDescription="@string/selectDate" />
    </LinearLayout>

    <View
        android:id="@+id/lineHeader"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDateSelect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivFixedDiaryPage"
        android:layout_width="0dp"
        android:layout_height="500dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="300dp"
        android:scaleType="fitXY"
        android:src="@drawable/diarypage"
        android:contentDescription="@string/diarypage"
        app:layout_constraintTop_toBottomOf="@id/lineHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- [중앙 콘텐츠 구역] 배경과 분리되어 스크롤 및 투명하게 처리된 레이어 -->

    <FrameLayout
        android:id="@+id/layoutDiaryContainer"
        android:layout_width="300dp"
        android:layout_height="450dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="0dp"
        android:paddingTop="50dp"
        android:paddingRight="20dp"
        android:paddingLeft="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="150dp"
        app:layout_constraintBottom_toBottomOf="@id/ivFixedDiaryPage"
        app:layout_constraintEnd_toEndOf="@id/ivFixedDiaryPage"
        app:layout_constraintStart_toStartOf="@id/ivFixedDiaryPage"
        app:layout_constraintTop_toTopOf="@+id/ivFixedDiaryPage">

        <TextView
            android:id="@+id/tvEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/entryHint"
            android:textColor="#999999"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- 하단 부가 제어선: 전체공개, 하이라이트, 저장 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutMetaActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarDecorate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnVisibility"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/flashcard_public"
            android:textColor="#555555"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/btnHighlightState"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/highlight"
            android:textColor="#555555"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintStart_toEndOf="@id/btnVisibility"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="70dp"
            android:layout_height="36dp"
            android:text="@string/save"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@android:color/darker_gray"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutPostItSetting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_comment_btn"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarDecorate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <!-- 색상 및 저장 버튼 바 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvSettingColorLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/colour"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_toEndOf="@id/tvSettingColorLabel"
                android:layout_marginStart="16dp"
                android:layout_centerVertical="true">
                <View android:id="@+id/viewColorOrange" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:background="#FFB6A6"/>
                <View android:id="@+id/viewColorYellow" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:background="#FFEBD3"/>
                <View android:id="@+id/viewColorGreen" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:background="#9BCEC1"/>
                <View android:id="@+id/viewColorBlue" android:layout_width="24dp" android:layout_height="24dp" android:background="#67A2C5"/>
            </LinearLayout>
            <TextView
                android:id="@+id/btnSettingSave"
                android:layout_width="60dp"
                android:layout_height="28dp"
                android:text="@string/nbsp"
                android:gravity="center"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <!-- 태그 라인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/tag"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <TextView
                android:id="@+id/chipTagDaily"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/tag_daily"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/chipTagWork"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/tag_work"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:layout_marginEnd="8dp"/>
            <LinearLayout
                android:id="@+id/layoutDynamicTagsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

            <!-- 태그 추가 + 버튼 -->
            <ImageView
                android:id="@+id/btnAddCustomTag"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_input_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                android:contentDescription="@string/add_tag" />
        </LinearLayout>

        <!-- 감정 라인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/feeling"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <LinearLayout
                android:id="@+id/layoutSelectedEmotionsContainer"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnSelectEmotion"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/select"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 반복주기 라인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/repeat_cycle"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <TextView
                android:id="@+id/btnRepeatAuto"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/repeat_auto"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_repeatauto"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnRepeatUser"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/repeat_user"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_repeatuser"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnRepeatNone"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/repeat_none"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_repeatnone"/>
        </LinearLayout>

        <!-- 종료일자 라인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/end_date"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <TextView
                android:id="@+id/btnEndDateNone"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/repeat_none"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_repeatnone"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnEndDateUser"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/repeat_user"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_repeatuser"/>
        </LinearLayout>

        <!-- 공개범위 라인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/f_visibility"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <TextView
                android:id="@+id/btnVisibilityPublic"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/flashcard_public"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_public"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnVisibilityFriendOnly"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/flashcard_onlyF"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_friendonly"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnVisibilityPrivate"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="@string/flashcard_private"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="#000000"
                android:background="@drawable/bg_private"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutEmotionPopup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_emotion"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarDecorate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feeling"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
            <TextView
                android:id="@+id/btnEmotionPopupConfirm"
                android:layout_width="60dp"
                android:layout_height="28dp"
                android:text="@string/nbsp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <!-- 감정 그리드/태그 배열 (요청하신 감정 키워드 4개씩 3줄 임베딩) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:id="@+id/emo1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#기뻐요" android:gravity="center" android:background="@drawable/bg_happy" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#신나요" android:gravity="center" android:background="@drawable/bg_excited" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#만족해요" android:gravity="center" android:background="@drawable/bg_satisfied" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#편안해요" android:gravity="center" android:background="@drawable/bg_relaxed" android:textSize="11sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:id="@+id/emo5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#짜증나요" android:gravity="center" android:background="@drawable/bg_annoyed" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#힘들어요" android:gravity="center" android:background="@drawable/bg_exhausted" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#화나요" android:gravity="center" android:background="@drawable/bg_angry" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo8" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#졸려요" android:gravity="center" android:background="@drawable/bg_sleepy" android:textSize="11sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/emo9" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#우울해요" android:gravity="center" android:background="@drawable/bg_depressed" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo10" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#속상해요" android:gravity="center" android:background="@drawable/bg_upset" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo11" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#불안해요" android:gravity="center" android:background="@drawable/bg_anxious" android:layout_marginEnd="4dp" android:textSize="11sp"/>
            <TextView android:id="@+id/emo12" android:layout_width="0dp" android:layout_weight="1" android:layout_height="26dp" android:text="#슬퍼요" android:gravity="center" android:background="@drawable/bg_sad" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 하단 툴바 1: 꾸미기 용도 (포스트잇추가, 형광펜, 텍스트, 이모지, 댓글) -->
    <LinearLayout
        android:id="@+id/layoutToolbarDecorate"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@android:color/darker_gray"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutToolbarNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnToolbarAdd"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="@string/createEmptyPostit" />

        <ImageButton
            android:id="@+id/btnToolbarPen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="@string/highlight" />

        <ImageButton
            android:id="@+id/btnToolbarText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_sort_alphabetically"
            android:contentDescription="@string/enterText" />

        <ImageButton
            android:id="@+id/btnToolbarComment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/sym_action_chat"
            android:contentDescription="셀프댓글(오늘 비활성화)" />
    </LinearLayout>

    <!-- 하단 툴바 2: 대메뉴 이동 네비게이션 링 -->
    <LinearLayout
        android:id="@+id/layoutToolbarNav"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@android:color/darker_gray"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <!--
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_agenda" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_book" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_gallery" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_myplaces" />
        <ImageView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:src="@android:drawable/ic_menu_manage" />
   -->
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>