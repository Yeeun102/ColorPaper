<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA"
    tools:context=".ui.flashcard.FlashcardStudyFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/tvSetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/set1"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#867070"/>

    <!-- 메인 암기 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#E4D0D0">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

    <!-- 외울 내용 (앞면 / 뒷면) -->
        <!-- [중앙] 외울 내용 (앞면 / 뒷면) -->
        <TextView
            android:id="@+id/tvCardContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/FlashcardFront"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp"/>

    <!-- 카드 하단 가이드 텍스트 -->
        <LinearLayout
            android:id="@+id/layoutCardNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="60dp">

            <Button
                android:id="@+id/tvFlipHint"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:text="@string/seeFlashcardBack"
                android:textColor="#867070"
                android:textSize="12sp"
                app:strokeColor="#867070" />

            <Button
                android:id="@+id/btnNextCard"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:text="@string/gotoNextFlashcard"
                android:textColor="#867070"
                android:textSize="12sp"
                app:strokeColor="#867070" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/layoutEmojiButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_alignParentBottom="true"
            android:visibility="gone"
            tools:visibility="visible">

            <Button
                android:id="@+id/btnAgain"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/againEmoji"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnHard"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hardEmoji"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnGood"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/goodEmoji"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnEasy"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/easyEmoji"
                android:textSize="18sp" />
        </LinearLayout>
    </RelativeLayout>
    </androidx.cardview.widget.CardView>



</LinearLayout>